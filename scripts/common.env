# Shared settings across all encoder combos.
# Sourced by every experiment script.

# Training
EPOCHS=1000
BATCH_SIZE=4096
EARLY_STOPPING=200
SEED=42
TEMPERATURE=0.05

# STRUCTURE reg
STRUCT_LAMBDA=10.0
STRUCT_LEVELS=1
STRUCT_WARMUP=1000

# Data
DATASET="coco"
DATA_PATH="data/COCO"

# Eval
EVAL_ZS_DATASETS="cifar10,cifar100,stl10,mnist,dtd,flowers,gtsrb,country211,imagenet"
EVAL_RETRIEVAL_DATASETS="coco,flickr30"

# Project root (resolved by each script via SCRIPT_DIR)
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Server B: glibc per-thread malloc arenas inflate VSZ, which under the
# container's vm.overcommit_memory=0 heuristic causes os.fork() to fail
# with ENOMEM when DataLoader workers spawn during text token extraction
# even though physical RAM is fine. Cap arenas to 2 to keep VSZ small.
export MALLOC_ARENA_MAX=2
