# ViT-S/14 DINOv2 + MiniLM-L6 config.
# Sourced after common.env by every script in this directory.

# Encoders
VISION_MODEL="vit_small_patch14_dinov2.lvd142m"
LANGUAGE_MODEL="sentence-transformers/all-MiniLM-L6-v2"
IMG_SIZE=224
DIM_IMG=384
DIM_TXT=384
ENCODER_TAG="vits_minilm"

# Alignment dims
DIM_ALIGNMENT=512        # for Linear, MLP
FA_EMBED_DIM=512         # for FreezeAlign
CSA_SIM_DIM=256          # for CSA (must be < PCA rank after n_components=0.999 whitening;
                         # at 384-dim input PCA keeps ~364 components, so 384 crashes)

# IMG_LAYER / TXT_LAYER are determined automatically via mutual kNN layer
# selection inside train_alignment.py (best_only: true in every config).
# No manual pinning needed.
