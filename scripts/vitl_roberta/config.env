# ViT-L/14 DINOv2 + RoBERTa-Large config.
# Sourced after common.env by every script in this directory.

# Encoders
VISION_MODEL="vit_large_patch14_dinov2.lvd142m"
LANGUAGE_MODEL="sentence-transformers/all-roberta-large-v1"
IMG_SIZE=224
DIM_IMG=1024
DIM_TXT=1024
ENCODER_TAG="vitl_roberta"

# Alignment dims
DIM_ALIGNMENT=512
FA_EMBED_DIM=512
CSA_SIM_DIM=512

# IMG_LAYER / TXT_LAYER are determined automatically via mutual kNN layer
# selection inside train_alignment.py (best_only: true in every config).
# No manual pinning needed.
