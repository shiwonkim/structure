# STRUCTURE — Environment-only image
# Code and data mounted at runtime via volumes

FROM pytorch/pytorch:2.1.2-cuda11.8-cudnn8-devel

ENV DEBIAN_FRONTEND=noninteractive

# System packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg libsm6 libxext6 sox git gcc g++ python3-dev \
    libglib2.0-0 libgl1-mesa-glx curl \
    && rm -rf /var/lib/apt/lists/*

# Node.js (required for Claude Code)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Claude Code
RUN npm install -g @anthropic-ai/claude-code

# Python packages — pinned versions verified during dry-run
COPY requirements.structure.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt && rm /tmp/requirements.txt

ENV PYTHONPATH="${PYTHONPATH}:/workspace/STRUCTURE"
ENV DS_BUILD_OPS=0
WORKDIR /workspace/STRUCTURE

CMD ["bash"]
